; Godot 4 scene file — bowling_lane.tscn
;
; Node tree (all dimensions in metres):
;
;   BowlingLane  (Node3D)
;     LaneFloor     (StaticBody3D)        lane surface  18 × 1.05 m
;       LaneMesh    (MeshInstance3D)
;       LaneCollision (CollisionShape3D)
